# =============================================================================
# Environment Variables — Template
# =============================================================================
# Copy this file to .env.local and fill in the values:
#   cp .env.example .env.local
#
# NEVER commit .env.local to version control!
# =============================================================================

# --- Next.js -----------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME={{PROJECT_NAME}}

# --- Supabase ----------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# The Supabase schema used by the application.
# Use "public" (default) or a custom schema name (e.g. "app", "live").
# Must match the schema exposed in Supabase → Project Settings → API → Exposed schemas.
# Also used by the GitHub deploy workflow (db_schema input) if you need to override Vercel's env.
SUPABASE_DB_SCHEMA=public

# --- Optional: Additional Services ------------------------------------------
# NEXT_PUBLIC_GA_TRACKING_ID=
# RESEND_API_KEY=
